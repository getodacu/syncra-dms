# Server hostname and port to listen on.
SERVER_HOST_PORT=localhost:8080

# Debug. Defaults to false when omitted.
DEBUG=false

# Version returned by GET /version. Defaults to dev when omitted.
APP_VERSION=dev

# PostgreSQL database DSNs. Both must target syncra_dev for local development.
DSN="host=localhost user=<postgres-user> password=<postgres-password> dbname=syncra_dev port=5432 sslmode=disable TimeZone=Europe/Bucharest"
DSN_DEV="host=localhost user=<postgres-user> password=<postgres-password> dbname=syncra_dev port=5432 sslmode=disable TimeZone=Europe/Bucharest"

# Atlas migration URL. Use the same database as DSN, in URL format.
ATLAS_DATABASE_URL="postgres://<postgres-user>:<postgres-password>@localhost:5432/syncra_dev?sslmode=disable"

# Atlas dev database URL. Use an empty scratch database, separate from syncra_dev.
ATLAS_DEV_DATABASE_URL="postgres://<postgres-user>:<postgres-password>@localhost:5432/syncra_atlas?sslmode=disable"

# Reserved for future trusted SvelteKit-to-Go /api/* requests.
SYNCRA_INTERNAL_API_TOKEN=""
