# Base URL for the Go API used by SvelteKit server hooks and form actions.
# Keep this private; browser code should not import it directly.
SYNCRA_API_BASE_URL="http://localhost:8080"

# Canonical local frontend origin.
SYNCRA_APP_ORIGIN="http://localhost:5173"

# Reserved for future trusted SvelteKit-to-Go /api/* requests.
SYNCRA_INTERNAL_API_TOKEN=""
