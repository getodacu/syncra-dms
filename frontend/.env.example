# Base URL for the Go API used by SvelteKit server hooks and form actions.
# Keep this private; browser code should not import it directly.
SYNCRA_API_BASE_URL="http://localhost:8080"

# Canonical local frontend origin.
SYNCRA_APP_ORIGIN="http://localhost:5173"

# Adapter-node request body limit. Must cover the 25 MiB Go document upload limit plus multipart overhead.
BODY_SIZE_LIMIT=26M

# Trusted SvelteKit-to-Go token for internal /api/auth/* requests.
SYNCRA_INTERNAL_API_TOKEN=""

# Must match the Go server AUTH_DELIVERY_TOKEN to send verification/reset emails.
AUTH_DELIVERY_TOKEN=""

# Set true when serving over HTTPS.
AUTH_COOKIE_SECURE=false

# SMTP configuration used by SvelteKit server actions for auth emails.
MAIL_SMTP_HOST=""
MAIL_SMTP_PORT="587"
MAIL_SMTP_USER=""
MAIL_SMTP_PASSWORD=""
MAIL_SMTP_FROM=""
MAIL_SMTP_TLS=true
