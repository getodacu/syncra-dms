# Base URL for the Go API used by SvelteKit server hooks and form actions.
# Keep this private; browser code should not import it directly.
SYNCRA_API_BASE_URL="http://localhost:8080"
SYNCRA_APP_ORIGIN="http://localhost:5173"
# Shared private token sent only by SvelteKit server-side requests to Go /api/* endpoints.
SYNCRA_INTERNAL_API_TOKEN=""


# Trusted delivery token sent only by SvelteKit server-side auth requests.
# Must match the backend's trusted auth delivery token configuration when enabled.
AUTH_DELIVERY_TOKEN=""

# Stripe secret values are used only by SvelteKit server routes.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Stripe Price IDs are one-time prices used by credit purchase tiers.
STRIPE_PRICE_ID_TIER_1=""
STRIPE_PRICE_ID_TIER_2=""
STRIPE_PRICE_ID_TIER_3=""
STRIPE_PRICE_ID_TIER_4=""

# Optional override for the auth session cookie secure flag.
# Leave blank to use the default: false in development, true outside development.
# Set to "true" when serving the frontend over HTTPS.
AUTH_COOKIE_SECURE=

# SMTP settings used by SvelteKit server actions to send auth emails.
MAIL_SMTP_HOST=<smtp-host>
MAIL_SMTP_PORT=<smtp-port>
MAIL_SMTP_USER=<smtp-user>
MAIL_SMTP_PASSWORD=<smtp-password>
MAIL_SMTP_FROM=<smtp-from>
MAIL_SMTP_TLS=<smtp-tls>
