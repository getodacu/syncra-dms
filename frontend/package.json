{
	"name": "syncra-dms-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
	"scripts": {
		"dev": "node scripts/run-and-normalize-paraglide.mjs vite dev",
		"build": "node scripts/run-and-normalize-paraglide.mjs vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && pnpm run paraglide:normalize || echo ''",
		"test": "svelte-kit sync && node scripts/run-and-normalize-paraglide.mjs vitest run",
		"check": "svelte-kit sync && pnpm run paraglide:normalize && svelte-check --tsconfig ./tsconfig.json && pnpm run paraglide:normalize",
		"check:watch": "svelte-kit sync && pnpm run paraglide:normalize && svelte-check --tsconfig ./tsconfig.json --watch",
		"paraglide:normalize": "node scripts/normalize-paraglide.mjs"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@inlang/paraglide-js": "2.19.0",
		"@inlang/plugin-m-function-matcher": "2.2.6",
		"@inlang/plugin-message-format": "4.4.0",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-toolbelt": "^0.10.6",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.7"
	}
}
