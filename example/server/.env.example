# Set to true in production.
IN_PRODUCTION=false
# server hostname and port to listen to
SERVER_HOST_PORT=localhost:8080

# Debug. Defaults to false when omitted.
DEBUG=false

# APP private key used to encrypt webhook secret keys
APP_PRIVATE_KEY="Vcy7WRusGXezBgGbi7QoC0QR2PiOaVwl"

# Postgresql Database DSN
DSN="host=<postgres-host> user=<postgres-user> password=<postgres-password> dbname=<postgres-db> port=5432 sslmode=disable TimeZone=<timezone>"
DSN_DEV="host=<postgres-host> user=<postgres-user> password=<postgres-password> dbname=<postgres-db> port=5432 sslmode=disable TimeZone=<timezone>"

# Atlas migration URL. Use the same database as DSN, in URL format.
ATLAS_DATABASE_URL="postgres://<postgres-user>:<postgres-password>@<postgres-host>:5432/<postgres-db>"
# Atlas dev database URL. Use an empty scratch database, separate from DSN and ATLAS_DATABASE_URL.
ATLAS_DEV_DATABASE_URL="postgres://<postgres-user>:<postgres-password>@<postgres-host>:5432/<atlas-dev-db>"

# Swagger
SWAGGER_HOST=localhost:8080
SWAGGER_SCHEMES=http

MISTRAL_API_KEY=<mistral-api-key>
MISTRAL_API_BASE_URL="https://api.mistral.ai"
MISTRAL_OCR_MODEL="mistral-ocr-latest"
MAX_UPLOAD_BYTES=20000000
# Optional. Defaults to server/.data when omitted.
# OCR uploads are stored in STORAGE_DIR/ocr-files and invoices in STORAGE_DIR/invoices.
STORAGE_DIR=


BETTER_AUTH_SECRET=""

# Google OAuth credentials used by the Go auth API for social login.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth credentials used by the Go auth API for social login.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Trusted delivery token used by SvelteKit server-side auth requests.
# Must match frontend AUTH_DELIVERY_TOKEN when email verification delivery is enabled.
AUTH_DELIVERY_TOKEN=""

# Credits granted once when a user first verifies/signs up. Defaults to 100.
ONBOARDING_CREDITS=100

# Shared private token required on SvelteKit server-to-Go /api/* requests.
SYNCRA_INTERNAL_API_TOKEN=""

OCR_EXECUTOR_WORKERS=4
OCR_EXECUTOR_POLL_INTERVAL_SECONDS=10
OCR_EXECUTOR_QUEUE_BUFFER=16

GOTENBERG_API_URL="http://home.arpa:3020/forms/chromium/convert/html"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
